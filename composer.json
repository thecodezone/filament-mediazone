{
    "name": "codezone/filament-mediazone",
    "description": "A media manager package for Laravel Filament.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Codezone",
            "email": "hello@codezone.io"
        }
    ],
    "keywords": ["laravel", "filament", "media", "media-manager", "livewire"],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.2",
        "intervention/image": "^2.7|^3.0",
        "livewire/livewire": "^3.0",
        "league/glide": "^2.0",
        "spatie/image": "^3.9",
        "spatie/laravel-sluggable": "^3.6",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.1",
        "orchestra/testbench": "^9.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Codezone\\MediaZone\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codezone\\MediaZone\\Tests\\": "tests/",
            "Codezone\\MediaZone\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codezone\\MediaZone\\MediaZoneServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
